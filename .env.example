# ─── Database ─────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-64-chars

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGIN=https://your-store.vercel.app,https://yourdomain.com

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Public URL of this backend (used for Tap webhook callback)
BACKEND_URL=https://your-backend.railway.app

# ─── Tap Payments ─────────────────────────────────────────────────────────────
# Get from: https://businesses.tap.company > Developers > API Keys
TAP_SECRET_KEY=sk_live_xxxxxxxxxxxx
# Test key for development:
# TAP_SECRET_KEY=sk_test_xxxxxxxxxxxx

# ─── Admin Seed (used only during first migration) ────────────────────────────
ADMIN_EMAIL=admin@yourstore.com
ADMIN_PASSWORD=ChangeThisImmediately!123
